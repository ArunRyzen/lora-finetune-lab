# This project needs NO API key by default — training runs on Colab/Kaggle,
# and everything local (lora synth / eval / config, all tests) is offline.
#
# One OPTIONAL live feature: with a Gemini key set (and `uv sync --extra gemini`),
# `lora eval` adds gemini-2.5-flash as a 4th contender — answering "would a strong
# hosted model, just prompted, already solve this?" Free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Learning aid: set to 1 to print every prompt/reply `lora eval` sends to its model
# contenders (offline fakes and Gemini alike) on stderr. Leave empty for silence.
# Setting it right here in your .env works; a real environment variable, when set,
# always takes precedence over this file (so `LLM_DEBUG=0` in your shell wins).
LLM_DEBUG=
